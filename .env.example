# Required
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Database paths (defaults to ./data/)
OPERATIONAL_DB_URL=sqlite:///./data/invoices.db
ANALYTICAL_DB_PATH=./data/analytics.db

# Data files
HISTORICAL_DATA_PATH=./data/historical_resolutions.json
REFERENCE_DATA_PATH=./data/reference_data.json

# Logging
LOG_LEVEL=INFO

# Resolution thresholds
AUTO_APPROVE_THRESHOLD=0.75
